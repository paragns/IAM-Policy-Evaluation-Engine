{
  "name": "logs-reader",
  "policies": [
    {
      "name": "LogsReadPolicy",
      "statements": [
        {
          "effect": "Allow",
          "action": "logs:GetLogEvents",
          "resource": "logs/*"
        },
        {
          "effect": "Allow",
          "action": "logs:DescribeLogGroups",
          "resource": "logs/*"
        }
      ]
    }
  ]
}
